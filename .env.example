# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/rag

# Storage
STORAGE_DIR=/srv/storage
MAX_UPLOAD_MB=100

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=rag-documents

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-openai>.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini

# Pipeline tuning
EMBED_BATCH_SIZE=16
CHUNK_TOKENS=800
CHUNK_OVERLAP=100
SEARCH_TOP_K_CHUNKS=30
SEARCH_TOP_K_DOCS=5
CHAT_MAX_CONTEXT_CHUNKS=12
INGEST_CONCURRENCY=2

# Feature flags
ENABLE_SEMANTIC_RANKING=true
ENSURE_INDEX_ON_STARTUP=true
