# ============================================================================
# RAG Ingestion & Search API — copy this file to `.env` (or `.env.dev`) and
# fill in the blanks. If both exist, `.env.dev` overrides `.env`.
# Every key below maps 1:1 to either docker-compose.yml or app/settings.py.
# ============================================================================

# ---------- REQUIRED: Azure AI Search ----------
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX=rag-documents

# ---------- REQUIRED: Azure OpenAI — chat deployment ----------
# Endpoint + key for the chat model (used by POST /search to generate the
# answer). Deployment = the name YOU chose in Azure OpenAI Studio.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_MODEL=
AZURE_OPENAI_API_VERSION=2024-10-21

# ---------- REQUIRED: Azure OpenAI — embedding deployment ----------
# Endpoint + key for the embedding model. Leave endpoint/api_key blank if your
# embedding model lives in the SAME resource as chat — the app will fall back
# to AZURE_OPENAI_ENDPOINT / AZURE_OPENAI_API_KEY automatically.
# Must output 1536 dims (e.g. text-embedding-3-small).
AZURE_OPENAI_EMBEDDING_ENDPOINT=
AZURE_OPENAI_EMBEDDING_API_KEY=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_MODEL=

# ---------- Database (SQLite) ----------
# DB file lives on the host at ./db/rag.db, bind-mounted into the container
# at /srv/db. The app's entrypoint runs `alembic upgrade head` on boot.
DATABASE_URL=sqlite+aiosqlite:////srv/db/rag.db

# ---------- Local file storage ----------
# Inside the container the compose bind mount puts ./storage at /srv/storage.
STORAGE_DIR=/srv/storage
MAX_UPLOAD_MB=100

# ---------- Pipeline tuning (safe defaults) ----------
EMBED_BATCH_SIZE=16
CHUNK_TOKENS=800
CHUNK_OVERLAP=100
SEARCH_TOP_K_CHUNKS=30
SEARCH_TOP_K_DOCS=5
CHAT_MAX_CONTEXT_CHUNKS=12
INGEST_CONCURRENCY=2

# ---------- Feature flags ----------
# Semantic reranking requires Azure AI Search Standard S1+. Set false on
# Free/Basic or the index creation call will fail.
ENABLE_SEMANTIC_RANKING=true
# Create-or-update the index on every startup. Set false if you manage the
# schema manually (e.g. created it from index.json via REST PUT).
ENSURE_INDEX_ON_STARTUP=true
