# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
dist/
wheels/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.cache/
nosetests.xml
coverage.xml

# Generated test fixtures (built on the fly by tests/conftest.py)
tests/fixtures/

# Environment & secrets
.env
.env.*
!.env.example

# IDEs & editors
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Docker image exports (large binary artifacts; rebuild with `docker build` instead)
docker-image/
*.tar
*.tar.gz

# Runtime storage
storage/uploads/*
!storage/uploads/.gitkeep

# SQLite database (incl. WAL/SHM sidecars)
db/*.db
db/*.db-*
!db/.gitkeep

# Type checkers
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
